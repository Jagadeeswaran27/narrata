#!/bin/bash
# Clean and install dependencies for Flutter, iOS, and Android

echo "🧹 Cleaning Flutter project..."
flutter clean

echo "📦 Getting Flutter dependencies..."
flutter pub get

echo "🍏 Resetting iOS dependencies..."
cd ios
rm -rf Pods
rm -f Podfile.lock
pod install --repo-update
cd ..

echo "🤖 Cleaning Android project..."
cd android
./gradlew clean
cd ..

echo "✅ Reset complete!"
